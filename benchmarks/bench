#!/usr/bin/env bash

if [[ $# != 1 || ($1 != "mainnet" && $1 != "preprod" && $1 != "data") ]]
then
  echo "Usage: ./bench [mainnet|preprod|data]"
  exit 1
fi

command -v oha &>/dev/null || { echo "Error: needs oha" >&2; exit 2; }

BASEURL="http://127.0.0.1:1442/matches"

if [[ $1 == "preprod" || $1 == "data" ]]
then
  PATTERNS=(
    # Tapioca Testnet [ TAPCT ] stake address (within "Top 100" on Cardanoscan.io)
    "stake_test1upyfx7klyd6lapdyqa0ku2ycgpnz9l8lmvp2ej989l6a69c0vnz0r"
    # Same address, the slot is chosen arbitrarily
    "stake_test1upyfx7klyd6lapdyqa0ku2ycgpnz9l8lmvp2ej989l6a69c0vnz0r?spent_after=98245654"
    # MIN token policy ID (biggest number of transations on first page of
    # https://preprod.cardanoscan.io/tokens
    "a9fc2c980e6beed499b91089ca06ad433961a6238690219b8021fe43.*"
    # Same address, the slot is chosen arbitrarily
    "a9fc2c980e6beed499b91089ca06ad433961a6238690219b8021fe43.*?created_before=98245654&spent_after=98764054"
    # Payment address with high transaction count (within "Top 100" on Cardanoscan.io)
    "addr_test1vzpwq95z3xyum8vqndgdd9mdnmafh3djcxnc6jemlgdmswcve6tkw"
    # Same address, the slot is chosen arbitrarily
    "addr_test1vzpwq95z3xyum8vqndgdd9mdnmafh3djcxnc6jemlgdmswcve6tkw?created_after=98677654&created_before=98764054"
    # All outputs to this arbitrary transaction ID
    "*@bc40cc86ed43d84d3367a7ff2f4a401dbaed885af96edf1c8fd7379402735699"
    # NEW: for ISSUE #194 - wildcard slot-range query
    "*?spent_after=98245654&spent_before=98245660"
  )
elif [[ $1 == "mainnet" ]]
then
  PATTERNS=(
    # A stake address that is associated with the jpg.store smart contract,
    # thus having a large number of transactions
    "stake1uxqh9rn76n8nynsnyvf4ulndjv0srcc8jtvumut3989cqmgjt49h6"
    # Same address, the slot is chosen arbitrarily but after jpg.store launch,
    # in order to still have results transactions before and after the slot.
    "stake1uxqh9rn76n8nynsnyvf4ulndjv0srcc8jtvumut3989cqmgjt49h6?spent_after=98245654"
    # World Mobile Token's policy id, which has been largely used without being
    # the most used
    "1d7f33bd23d85e1a25d87d86fac4f199c3197a2f7afeb662a0f34e1e.*"
    # Same address, the slot is chosen arbitrarily (or at least, I cannot remember why).
    "1d7f33bd23d85e1a25d87d86fac4f199c3197a2f7afeb662a0f34e1e.*?created_before=98245654&spent_after=98764054"
    # A payment/wallet address that has many transactions (can't remember the
    # exact reason I picked this one?)
    "addr1v94725lv4umktv89cg2t04qjn4qq3p6l6zegvtx5esu2zuqfd487u"
    # Same address, the slot is chosen arbitrarily
    "addr1v94725lv4umktv89cg2t04qjn4qq3p6l6zegvtx5esu2zuqfd487u?created_after=98677654&created_before=98764054"
    # All outputs to one arbitrary transaction (was probably picked by looking at
    # the latest transaction in an explorer at the moment of writing this bench!)
    "*@4301551ce28e83ef1082432f57a13bbbd389f4628592b73d71ca19e8833c0eb7"
  )
fi

if [[ $1 == "data" ]]
then
  exp_headers="request-start,DNS,DNS+dialup,Response-delay,request-duration,bytes,status"
  got_headers=$(oha -n 1 -c 1 --output-format csv "$BASEURL/${PATTERNS[0]}" | head -1)
  if [ "$exp_headers" = "$got_headers" ]
  then
    count=0
    dir=data/$(date +%Y%m%d-%H%M%S)
    mkdir -p $dir
    rm -f index
    for PATTERN in ${PATTERNS[@]}; do
      for QUERY in "$PATTERN"; do
        ((count++))
        echo "$count: ${QUERY}" >> index
        oha -n 111 -c 2 --output-format csv "$BASEURL/$QUERY" | tail +3 | awk -F',' '{print $7, $4}' > $dir/$count
      done
    done
  else
    echo "Expected: $exp_headers"
    echo "But got : $got_headers"
    exit 3
  fi
else
  for PATTERN in ${PATTERNS[@]}; do
    for QUERY in "$PATTERN"; do
      echo "$BASEURL/$QUERY"
      oha -n 30 -c 8 "$BASEURL/$QUERY"
      echo -e "\nTotal results\n $(curl -s "$BASEURL/$QUERY" | jq length)\n"
      echo ""
    done
  done
fi

